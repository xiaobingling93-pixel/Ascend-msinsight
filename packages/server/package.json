{
    "name": "profiler-server",
    "version": "1.0.0",
    "main": "app.js",
    "license": "MIT",
    "bin": "./dist/app.js",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "dependencies": {
        "crypto-js": "^4.1.1",
        "log4js": "6.7.1",
        "lodash": "4.17.21",
        "sqlite3": "^5.1.5",
        "threads": "^1.7.0",
        "ws": "^8.13.0"
    },
    "devDependencies": {
        "node-pre-gyp": "0.12.0",
        "@types/crypto-js": "^4.1.1",
        "@types/ws": "^8.5.4",
        "@typescript-eslint/eslint-plugin": "^5.59.2",
        "cross-env": "^7.0.3",
        "eslint": "^8.40.0",
        "eslint-config-standard-with-typescript": "^22.0.0",
        "eslint-plugin-import": "^2.25.3",
        "eslint-plugin-n": "^15.7.0",
        "eslint-plugin-promise": "^6.0.0",
        "jest": "^29.6.2",
        "@babel/core": "^7.22.5",
        "@babel/preset-env": "^7.22.9",
        "@babel/preset-typescript": "^7.22.5",
        "@types/jest": "^29.5.3",
        "@types/lodash": "^4.14.182",
        "typescript": "^4.2.3"
    },
    "scripts": {
        "packageWin": "npm run copyWin && cd buildServer && npm install && npm run packWin",
        "packageLinuxX64": "npm run copyLinux && cd buildServer && npm install && npm run packLinux",
        "build": "cross-env NODE_ENV=production eslint ./src && tsc -p tsconfig-prod.json",
        "build:dev": "eslint ./src && tsc",
        "start": "eslint ./src && tsc && node ./dist/app.js",
        "package": "npm run packageWin&&npm run packageLinuxX64",
        "copyWin": "xcopy .\\dist\\* .\\buildServer\\ /E /I /Y",
        "copyLinux": "cp -R ./dist/* ./buildServer",
        "test": "jest --coverage",
        "test:dev": "jest --watch"
    },
    "pkg": {
        "scripts": [
            "./dist/*.js"
        ],
        "assets": [
            "./node_modules/sqlite3/**/*.node"
        ]
    }
}
