{
    "name": "profiler-server",
    "version": "1.0.0",
    "main": "app.js",
    "license": "MIT",
    "bin": "./dist/app.js",
    "private": true,
    "dependencies": {
        "crypto-js": "^4.1.1",
        "sqlite3": "^5.1.5",
        "ws": "^8.5.0"
    },
    "devDependencies": {
        "node-pre-gyp": "0.12.0",
        "@types/crypto-js": "^4.1.1",
        "@types/ws": "^8.5.4",
        "@typescript-eslint/eslint-plugin": "^5.59.2",
        "eslint": "^8.40.0",
        "eslint-config-standard-with-typescript": "^22.0.0",
        "eslint-plugin-import": "^2.25.3",
        "eslint-plugin-n": "^15.7.0",
        "eslint-plugin-promise": "^6.0.0",
        "typescript": "^4.2.3"
    },
    "scripts": {
        "packageWin": "npm run copyWin && cd buildServer && npm install && npm run packWin",
        "packageLinuxX64": "npm run copyLinux && cd buildServer && npm install && npm run packLinux",
        "build": "eslint ./src && tsc ",
        "start": "eslint ./src && tsc && node ./dist/app.js",
        "package": "npm run packageWin&&npm run packageLinuxX64",
        "copyWin": "xcopy .\\dist\\* .\\buildServer\\ /E /I /Y",
        "copyLinux": "cp -R ./dist/* ./buildServer"
    },
    "pkg": {
        "scripts": [
            "./dist/*.js"
        ],
        "assets": [
            "./node_modules/sqlite3/**/*.node"
        ]
    }
}
