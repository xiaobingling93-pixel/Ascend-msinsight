{
    "name": "profiler-server",
    "version": "1.0.0",
    "main": "app.js",
    "license": "MIT",
    "bin": "./dist/app.js",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "dependencies": {
        "crypto-js": "^4.1.1",
        "sqlite3": "^5.1.5",
        "threads": "^1.7.0",
        "ws": "^8.13.0"
    },
    "devDependencies": {
        "node-pre-gyp": "0.12.0",
        "@types/crypto-js": "^4.1.1",
        "@types/ws": "^8.5.4",
        "@typescript-eslint/eslint-plugin": "^5.59.2",
        "eslint": "^8.40.0",
        "eslint-config-standard-with-typescript": "^22.0.0",
        "eslint-plugin-import": "^2.25.3",
        "eslint-plugin-n": "^15.7.0",
        "eslint-plugin-promise": "^6.0.0",
        "typescript": "^4.2.3",
        "pkg": "^5.8.1"
    },
    "scripts": {
        "package": "pkg . -t nodev14-win-x64 --compress GZip",
        "build": "eslint ./src && tsc ",
        "start": "eslint ./src && tsc && node ./dist/app.js"
    },
    "pkg": {
        "scripts": [
            "./dist/*.js"
        ],
        "assets": [
            "./node_modules/sqlite3/**/*.node"
        ]
    }
}
