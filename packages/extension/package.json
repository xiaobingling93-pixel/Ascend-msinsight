{
    "name": "ascend-insight-extension",
    "displayName": "ascend-insight-extension",
    "description": "",
    "version": "6.0.3",
    "engines": {
        "vscode": "^1.63.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "ascend-insight.start",
                "title": "ascend-insight.start"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "ascend-insight.start",
                    "when": "editorTextFocus && !editorReadonly",
                    "title": "ascend-insight.start"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "webpack",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "vsce:package": "vsce package",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js",
        "dev": "bash -exec 'code --extensionDevelopmentPath=$(pwd)'",
        "publish-extension": "vsce package $(node -e \"console.log(require('./package.json').version)\")"
    },
    "devDependencies": {
        "@types/glob": "^7.1.4",
        "@types/node": "18.14.1",
        "@types/vscode": "^1.63.0",
        "@typescript-eslint/eslint-plugin": "^5.1.0",
        "@typescript-eslint/parser": "^5.1.0",
        "copy-webpack-plugin": "^11.0.0",
        "eslint": "^8.1.0",
        "glob": "^7.1.7",
        "ts-loader": "9.4.4",
        "vsce": "2.9.2",
        "vscode-languageclient": "^6.1.0",
        "webpack": "^5.52.1",
        "webpack-cli": "^4.8.0",
        "typescript": "4.9.5"
    },
    "LICENSE": "HuaWei Technology",
    "publisher": "PAP",
    "repository": {
        "url": ""
    }
}
