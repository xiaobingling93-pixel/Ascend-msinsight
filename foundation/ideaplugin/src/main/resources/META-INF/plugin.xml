<idea-plugin>
    <!--插件基本信息-->
    <id>com.huawei.ascend.AscendInsight</id>
    <name>AscendInsight</name>
    <vendor email="harmonysupport@huawei.com" url="https://developer.harmonyos.com/">Huawei</vendor>
    <description><![CDATA[DevEco Insight is a performance optimization tool.<br>]]></description>

    <!--依赖的插件-->
    <depends>com.intellij.modules.platform</depends>
    <!--i18n资源-->
    <resource-bundle>message.en</resource-bundle>
    <resource-bundle>message.zh</resource-bundle>

    <!--实现intellij底座拓展点，Insight主体-->
    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Ascend Insight" factoryClass="com.huawei.ascend.insight.InsightWindowFactory" anchor="bottom"
                    icon="/META-INF/pluginIcon.svg"/>
        <applicationService serviceImplementation="com.huawei.ascend.insight.data.InsightCfgPreferences"/>
        <notificationGroup id="Insight" displayType="BALLOON"/>
    </extensions>
</idea-plugin>