{
  "name": "ascend-cluster",
  "version": "0.1.0",
  "private": true,
  "homepage": "./",
  "dependencies": {
    "@emotion/react": "11.11.0",
    "@emotion/styled": "11.11.0",
    "antd": "4.24.13",
    "d3": "7.8.2",
    "lodash": "4.17.21",
    "mobx": "6.10.0",
    "mobx-react": "9.0.0",
    "react-i18next": "12.1.4",
    "i18next": "23.4.6",
    "echarts": "5.4.3",
    "@cloudsop/horizon": "0.0.71"
  },
  "devDependencies": {
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.7",
    "@craco/craco": "7.1.0",
    "@playwright/test": "1.36.0",
    "@testing-library/jest-dom": "5.17.0",
    "@testing-library/react": "14.0.0",
    "@testing-library/user-event": "14.4.3",
    "@testing-library/react-hooks": "8.0.1",
    "@types/d3": "7.4.0",
    "@types/emscripten": "1.39.7",
    "@types/jest": "27.5.2",
    "@types/lodash": "4.14.197",
    "@types/node": "18.14.1",
    "@types/shallowequal": "1.1.1",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "cross-env": "7.0.3",
    "eslint": "8.47.0",
    "eslint-config-standard-with-typescript": "22.0.0",
    "html-inline-css-webpack-plugin": "^1.11.2",
    "html-inline-script-webpack-plugin": "^3.2.1",
    "html-webpack-inline-source-plugin": "^0.0.10",
    "html-webpack-plugin": "^5.5.3",
    "eslint-plugin-import": "2.28.0",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-n": "15.7.0",
    "eslint-plugin-promise": "6.1.1",
    "eslint-plugin-react": "7.33.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "react-scripts": "5.0.1",
    "typescript": "4.9.5",
    "typescript-plugin-css-modules": "3.4.0"
  },
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--openssl-legacy-provider craco start",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider NODE_ENV=production GENERATE_SOURCEMAP=false CI=false craco build",
    "build:dev": "cross-env GENERATE_SOURCEMAP=true CI=false craco build",
    "test": "set REACT_APP_TEST=1&&set CI=true&&react-scripts test --watchAll=false  --coverage",
    "test:dev": "set REACT_APP_TEST=1&&react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src --fix",
    "dt": "set BROWSER=none&&set REACT_APP_TEST=1&&react-scripts start",
    "publishWin": "xcopy .\\build ..\\..\\framework\\plugins\\Cluster\\ /E /I /Y",
    "publishLinux": "cp -rf ./build/* ../../framework/plugins/Cluster"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "jest": {
    "transformIgnorePatterns": [
      "/node_modules/(?!d3|d3-array)"
    ],
    "clearMocks": true,
    "coverageReporters": [
      "json",
      "lcov",
      "text",
      "text-summary"
    ],
    "collectCoverageFrom": [
      "**/src/**/*.{ts,tsx}"
    ],
    "coveragePathIgnorePatterns": [
      "<rootDir>/src/i18n",
      "<rootDir>/src/style",
      "<rootDir>/src/insight",
      "<rootDir>/src/tests",
      ".d.ts",
      ".type.ts",
      ".const.ts",
      ".mock.[ts,tsx]",
      "index.[ts,tsx]",
      "types.ts",
      "__mocks__",
      "__snapshots__"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 0,
        "branches": 0,
        "functions": 0,
        "lines": 0
      }
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
