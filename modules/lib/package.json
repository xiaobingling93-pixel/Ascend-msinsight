{
  "name": "common",
  "version": "0.1.0",
  "private": true,
  "main": "src/lib.js",
  "types": "src/lib.d.ts",
  "scripts": {
    "start": "cross-env NODE_OPTIONS='--openssl-legacy-provider --max_old_space_size=4096' craco start",
    "build": "cross-env NODE_OPTIONS='--openssl-legacy-provider --max_old_space_size=4096' NODE_ENV=production GENERATE_SOURCEMAP=false CI=false tsc --declaration",
    "dev": "cross-env NODE_OPTIONS=--openssl-legacy-provider tsc --declaration",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "publishWin": "xcopy .\\build ..\\framework\\public\\plugins\\lib\\ /E /I /Y",
    "publishLinux": "cp -rf ./build/* ../framework/public/plugins/lib",
    "cleanWin": "del /q /f /s .\\src\\index.d.ts"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
