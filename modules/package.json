    "private": true,
    "scripts": {
        "buildModuleWin": "pnpm install && pnpm build && pnpm publishWin",
        "buildModuleLinux": "pnpm install && pnpm build && pnpm publishLinux",
        "build":"pnpm -r build",
        "publishWin":"pnpm -r publishWin",
        "publishLinux":"pnpm -r publishLinux",
        "test": "pnpm install && pnpm testMemory && pnpm testTimeline",
        "testCluster": "cd cluster && pnpm test",
        "testMemory": "cd memory && pnpm test",
        "testTimeline": "cd timeline && pnpm test"
    },
